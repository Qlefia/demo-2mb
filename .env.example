# 2mb CRM — environment variables
# Copy to .env.local and fill values. Never commit .env.local.

# --- App ---
# Optional: site URL for absolute links in dev
# Optional: full-bleed image on the right side of /login and /register (URL or absolute path).
# NEXT_PUBLIC_AUTH_MARKETING_IMAGE=https://example.com/hero.jpg

# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Authenticated Impeccable scan (npm run design:impeccable:auth) — never commit real passwords
# IMPECCABLE_AUTH_EMAIL=
# IMPECCABLE_AUTH_PASSWORD=
# IMPECCABLE_BASE_URL=http://127.0.0.1:3000

# --- Supabase (project: 2mb, region: eu-west-1) ---
# From Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Used by Edge Functions, Supabase Cron, and server actions. NEVER ship to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Postgres connection for Drizzle (server-side only).
# Use the Supabase shared connection pooler in TRANSACTION mode (port 6543, IPv4+IPv6).
# Drizzle is configured with prepare:false to play well with pgBouncer transaction mode.
# Format: postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Used by POST /api/inbound (optional). Omit to disable the route (503).
# Send as header X-Webhook-Secret or Authorization: Bearer …
INBOUND_WEBHOOK_SECRET=

# Remove from .env after the founder user is created.
BOOTSTRAP_FOUNDER_EMAIL=
BOOTSTRAP_FOUNDER_PASSWORD=
# Shared password for seeded dev test seats (ops/sales); required for npm run smoke:rls-prospects / CI.
DEV_TEST_USERS_PASSWORD=

# --- Enrichment internal calls (Edge Function → Vercel API) ---
# Same secret in Supabase Edge secrets (ENRICH_INTERNAL_SECRET) and here.
# CRM_API_BASE_URL = deployed app origin only (used in Edge function env on Supabase).
ENRICH_INTERNAL_SECRET=
# CRM_API_BASE_URL=https://your-app.vercel.app

# --- Enrichment providers (server-only) ---
APOLLO_API_KEY=
# Optional daily ceiling for Ops Today quota display (no hard block yet)
# APOLLO_DAILY_LIMIT=500
PHANTOMBUSTER_API_KEY=
BROWSE_AI_API_KEY=
NEWSAPI_API_KEY=
# Optional daily ceiling for NewsAPI free tier display + blocking (default 100)
NEWSAPI_DAILY_LIMIT=100
# Wayback Machine has no key — public.

# --- AI providers (server-only) ---
# Primary LLM for dossier generation
ANTHROPIC_API_KEY=
# Optional override for Anthropic API model id (default from prompt frontmatter)
ANTHROPIC_MODEL=
# Fallback / alternate provider (also used for embeddings: text-embedding-3-large)
OPENAI_API_KEY=

# Choose primary AI provider: 'anthropic' (default) or 'openai'
AI_PROVIDER=anthropic

# --- Optional integrations ---
# Slack incoming webhook for handoff notifications
# SLACK_WEBHOOK_URL=

# --- Sales comms: Easybell (VoIP) + IONOS (email) ---
# Phase 0 (now): tel:/mailto: — no env vars; works with marketer's Easybell app + IONOS mailbox in OS.
# Phase 1 (when credentials arrive — see BACKLOG #70):
# EASYBELL_API_TOKEN=
# EASYBELL_SIP_USER=
# IONOS_SMTP_HOST=smtp.ionos.de
# IONOS_SMTP_USER=
# IONOS_SMTP_PASSWORD=

# --- Optional analytics placeholders ---
# NEXT_PUBLIC_SENTRY_DSN=
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=
